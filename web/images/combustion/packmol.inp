filetype xyz
output model.xyz
tolerance 4.0

# C2H6O + 3 O2 -> 2CO2 + 3H2O
# Atoms: 15
# Mass: 46 + 96 = 142
# 0.1 g/mL = 60.2 Da / nm^3
# 100x ratio, 1500 Atoms, 14200 Da, 235.88 nm^3, 6.178 nm / axis

structure ethanol.xyz
    number 100
    inside box 0 0 0 67.18 67.18 67.18
end structure

structure oxygen.xyz
    number 300
    inside box 0 0 0 67.18 67.18 67.18
end structure